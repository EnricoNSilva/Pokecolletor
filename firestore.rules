rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;

      match /binderCards/{cardId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /decks/{deckId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}